{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collaborative-dynamics.local/schemas/agent-striving-pursuit-state-v1.json",
  "title": "Agent Striving Pursuit State v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "pursuit_id",
    "objective",
    "world_change",
    "acceptance_criteria",
    "status",
    "strategy",
    "progress",
    "next_move",
    "budgets",
    "authority",
    "completion_evidence",
    "reentry",
    "updated_at"
  ],
  "properties": {
    "format": {"const": "cd-agent-striving-state/v1"},
    "pursuit_id": {"type": "string", "minLength": 1},
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "source_authority", "source_refs"],
      "properties": {
        "statement": {"type": "string", "minLength": 1},
        "source_authority": {"type": "string", "minLength": 1},
        "source_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "world_change": {"type": "string", "minLength": 1},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "status": {
      "enum": [
        "active",
        "completed",
        "partial-success",
        "awaiting-evidence",
        "awaiting-authority",
        "capability-limited",
        "budget-exhausted",
        "paused",
        "cancelled",
        "killed"
      ]
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_hypothesis", "last_revision"],
      "properties": {
        "current_hypothesis": {"type": "string", "minLength": 1},
        "last_revision": {"type": ["string", "null"]}
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified_outcomes", "evidence_refs", "remaining", "stall_count"],
      "properties": {
        "verified_outcomes": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "remaining": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "stall_count": {"type": "integer", "minimum": 0}
      }
    },
    "next_move": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "rationale", "authority_required"],
      "properties": {
        "action": {"type": "string", "minLength": 1},
        "rationale": {"type": "string"},
        "authority_required": {"type": "boolean"}
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limits", "used", "exhausted_dimension"],
      "properties": {
        "limits": {"type": "object"},
        "used": {"type": "object"},
        "exhausted_dimension": {"type": ["string", "null"]}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_actions", "gated_actions", "pending_gate"],
      "properties": {
        "allowed_actions": {"type": "array", "items": {"type": "string"}},
        "gated_actions": {"type": "array", "items": {"type": "string"}},
        "pending_gate": {"type": ["string", "null"]}
      }
    },
    "completion_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "reentry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "next_actor"],
      "properties": {
        "condition": {"type": "string", "minLength": 1},
        "next_actor": {"type": "string", "minLength": 1}
      }
    },
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
